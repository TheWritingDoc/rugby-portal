# ===== Frontend (Vite) =====
# API base URL of the deployed server, e.g. https://api.example.com/api
VITE_API_BASE=

# Google Sign-In (OAuth client ID from https://console.cloud.google.com/apis/credentials)
# The Google button on the Login page only appears when this is set.
VITE_GOOGLE_CLIENT_ID=

# Facebook Login (App ID from https://developers.facebook.com/apps)
# The Facebook button on the Login page only appears when this is set.
VITE_FACEBOOK_APP_ID=

# ===== Server (NODE_ENV=production node server/index-sqlite.js) =====
# REQUIRED in production — the server refuses to boot without it.
JWT_SECRET=

# Must match VITE_GOOGLE_CLIENT_ID; used to verify the Google token audience.
GOOGLE_CLIENT_ID=

# Used to verify Facebook access tokens server-side (recommended in production).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Comma-separated list of allowed browser origins, e.g. https://portal.example.com
# Leave empty to allow all origins (development only).
ALLOWED_ORIGINS=

# PORT=4000
