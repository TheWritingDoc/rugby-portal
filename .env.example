# ============================================================================
# Rugby Portal — environment variables
# Copy to .env for local dev. On Vercel, set these under
# Project → Settings → Environment Variables (do NOT commit real values).
# ============================================================================

# ===== Frontend (Vite, build-time) =====
# Leave EMPTY for the Vercel deploy — the API is same-origin at /api.
# Only set this if the API is hosted on a different domain.
VITE_API_BASE=

# Google Sign-In (OAuth client ID). The Google button only appears when set.
VITE_GOOGLE_CLIENT_ID=
# Facebook Login (App ID). The Facebook button only appears when set.
VITE_FACEBOOK_APP_ID=

# ===== Database =====
# When DATABASE_URL is set, the server uses Postgres (Supabase). When unset,
# it falls back to a local SQLite file (zero-config local development).
# Supabase: Project → Settings → Database → Connection string → "URI".
# Use the connection POOLER string (port 6543) for serverless/Vercel.
# Example:
# DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ===== File uploads (Supabase Storage) =====
# When both are set, uploads go to Supabase Storage; otherwise to local disk.
# Supabase: Project → Settings → API.
SUPABASE_URL=
# Service-role key — server-side ONLY, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Name of the public Storage bucket to upload into (create it in Supabase).
SUPABASE_BUCKET=uploads

# ===== Auth / security (server) =====
# REQUIRED in production — the server refuses to boot without it.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Must match VITE_GOOGLE_CLIENT_ID; used to verify the Google token audience.
GOOGLE_CLIENT_ID=
# Used to verify Facebook access tokens server-side (recommended in production).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Comma-separated allowed browser origins, e.g. https://your-app.vercel.app
# Leave empty to allow all origins (development only).
ALLOWED_ORIGINS=

# PORT=4000               # local self-hosting only (ignored on Vercel)
# PG_POOL_MAX=5           # max Postgres pool connections per function instance
